                  ],
                  "children": [
                    {
                      "type": "text",
                      "id": "1QxVx",
                      "fill": "$accent",
                      "content": "use tokio::sync::mpsc;",
                      "fontFamily": "Geist Mono",
                      "fontSize": 13
                    },
                    {
                      "type": "text",
                      "id": "O0WFt",
                      "fill": "$text-dim",
                      "content": " ",
                      "fontFamily": "Geist Mono",
                      "fontSize": 13,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "mMWpL",
                      "fill": "$accent",
                      "content": "pub struct StateMachine<S> {",
                      "fontFamily": "Geist Mono",
                      "fontSize": 13
                    },
                    {
                      "type": "text",
                      "id": "m7CaO",
                      "fill": "$text-secondary",
                      "content": "    state: S,",
                      "fontFamily": "Geist Mono",
                      "fontSize": 13
                    },
                    {
                      "type": "text",
                      "id": "N266d",
